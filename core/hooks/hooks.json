          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "id": "forge.core.block-force-push",
            "type": "command",
            "command": "node {{FORGE_ROOT}}/core/hooks/scripts/block-force-push.js"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "id": "forge.core.secret-detector",
            "type": "command",
            "command": "node {{FORGE_ROOT}}/core/hooks/scripts/secret-detector.js"
          }
        ],
        "matcher": "Write"
      },
      {
        "hooks": [
          {
            "id": "forge.core.secret-detector-edit",
            "type": "command",
            "command": "node {{FORGE_ROOT}}/core/hooks/scripts/secret-detector.js"
          }
