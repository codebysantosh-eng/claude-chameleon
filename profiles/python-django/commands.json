{
  "profile": "python-django",
  "filePatterns": ["**/*.py", "manage.py", "*/settings*.py"],
  "commands": {
    "test": "pytest --cov --cov-report=term",
    "lint": "ruff check . && black --check .",
    "format": "black .",
    "typecheck": "mypy .",
    "build": null,
    "audit": "pip audit",
    "e2e": "playwright test",
    "coverage": "pytest --cov --cov-report=term-missing"
  }
}
